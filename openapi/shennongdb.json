{
  "openapi": "3.1.0",
  "info": {
    "title": "ShennongDB Headless Data Plane API",
    "version": "1.0.0",
    "description": "Internal V1 service contract. ShennongDB is not browser-facing and does not own product identity, chat, memory, provider credentials, or Project membership. Shennong OS authenticates users and proxies only this fixed data-plane allowlist. Research Project rows are data-plane shadows synchronized by OS; owner_user_id is an opaque OS identifier, not a ShennongDB identity foreign key."
  },
  "servers": [{ "url": "/" }],
  "security": [{ "adminKey": [] }],
  "x-shennong-profile": "headless",
  "paths": {
    "/health": { "get": { "security": [], "operationId": "health", "responses": { "200": { "$ref": "#/components/responses/Success" } } } },
    "/healthz": { "get": { "security": [], "operationId": "readiness", "responses": { "200": { "$ref": "#/components/responses/Success" }, "503": { "$ref": "#/components/responses/Unavailable" } } } },
    "/metrics": { "get": { "security": [], "operationId": "metrics", "responses": { "200": { "description": "Prometheus text metrics" } } } },
    "/version": { "get": { "security": [], "operationId": "version", "responses": { "200": { "$ref": "#/components/responses/Success" } } } },
    "/.well-known/shennong-agent.json": { "get": { "operationId": "wellKnownAgentManifest", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },

    "/api/v1/resources": { "get": { "operationId": "listResources", "description": "Lists a server-bounded Resource page. Results are ordered by id and the numeric cursor is compatible with offset.", "parameters": [{ "name": "q", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 256 } }, { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 } }, { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 0, "maximum": 1000000, "default": 0 } }, { "name": "cursor", "in": "query", "required": false, "description": "Decimal offset cursor. If offset is also present, both values must match.", "schema": { "type": "string", "pattern": "^[0-9]+$" } }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/resources/{id}": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "getResource", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } }, "put": { "operationId": "putResource", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/resources/{id}/artifacts": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "listArtifacts", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "putArtifact", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/resources/{id}/artifacts/{artifact_id}/download": { "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ArtifactId" }], "get": { "operationId": "downloadArtifact", "responses": { "200": { "description": "Artifact byte stream" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/resources/{id}/relations": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "listRelations", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "putRelation", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/resources/{id}/graph-context": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "getResourceGraphContext", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/resources/{id}/revisions": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "listResourceRevisions", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "createResourceRevision", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/resources/{id}/revisions/{revision}": { "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/Revision" }], "get": { "operationId": "getResourceRevision", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/resources/install": { "post": { "operationId": "installResource", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/providers": { "get": { "operationId": "listProviders", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/capabilities": { "get": { "operationId": "getCapabilities", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/storage": { "get": { "operationId": "getStorage", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/cache/stats": { "get": { "operationId": "getCacheStats", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/cache": { "delete": { "operationId": "clearCache", "responses": { "204": { "$ref": "#/components/responses/NoContent" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/audit-events": { "get": { "operationId": "listAuditEvents", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/ingestion-jobs": { "get": { "operationId": "listIngestionJobs", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/agent-manifest": { "get": { "operationId": "agentManifest", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/agent/resources/{id}": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "getAgentResource", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/agent/resources/{id}/metadata": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "getAgentResourceMetadata", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/agent/resources/{id}/axes/{axis}": { "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/Axis" }], "get": { "operationId": "getAgentResourceAxis", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/genes/resolve": { "get": { "operationId": "resolveGene", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/query": { "post": { "operationId": "query", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/query/batch": { "post": { "operationId": "queryBatch", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/query/stream": { "post": { "operationId": "queryStream", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "description": "Streamed query response" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/uploads": { "parameters": [{ "name": "X-Shennong-OS-Actor-ID", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" }, "description": "Opaque OS actor UUID; accepted only with the headless service-admin credential." }, { "name": "X-Shennong-OS-Project-ID", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" }, "description": "Authoritative OS Project UUID; accepted only with the headless service-admin credential." }], "get": { "operationId": "listUploads", "description": "Lists uploads scoped to the injected OS Project UUID.", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } }, "post": { "operationId": "upload", "description": "Streams one non-empty file and records its SHA-256 inside the injected OS actor/Project boundary.", "parameters": [{ "name": "X-Filename", "in": "header", "required": true, "schema": { "type": "string", "minLength": 1, "maxLength": 255 } }, { "name": "Content-Length", "in": "header", "required": true, "schema": { "type": "integer", "minimum": 1 } }], "requestBody": { "required": true, "content": { "application/octet-stream": { "schema": { "type": "string", "format": "binary" } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "413": { "description": "Upload exceeds configured limit" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/uploads/register": { "parameters": [{ "name": "X-Shennong-OS-Actor-ID", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }, { "name": "X-Shennong-OS-Project-ID", "in": "header", "required": true, "schema": { "type": "string", "format": "uuid" } }], "post": { "operationId": "registerUploads", "description": "Atomically registers uploads owned by the exact injected actor and Project, creates immutable Artifacts, and binds the private Resource to that Project.", "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["upload_ids", "resource_id", "name"], "properties": { "upload_ids": { "type": "array", "minItems": 1, "maxItems": 100, "items": { "type": "string", "format": "uuid" } }, "resource_id": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9._-]+$" }, "name": { "type": "string", "minLength": 1, "maxLength": 512 }, "description": { "type": "string", "maxLength": 4096 }, "format": { "type": "string", "minLength": 1, "maxLength": 64 }, "data_class": { "type": "string", "enum": ["raw", "canonical", "derived"] }, "visibility": { "type": "string", "enum": ["private"] } } } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/backups": { "get": { "operationId": "listBackups", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "createBackup", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/backups/{backup_id}/restore": { "parameters": [{ "$ref": "#/components/parameters/BackupId" }], "post": { "operationId": "restoreBackup", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },

    "/api/v1/research-projects": { "get": { "operationId": "listResearchProjects", "description": "Lists data-plane Project shadows. Shennong OS remains authoritative for Project RBAC.", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/research-projects/{project_id}": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "getResearchProject", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } }, "put": { "operationId": "syncResearchProjectShadow", "description": "Idempotently creates or updates the ShennongDB shadow of an OS-owned Project. This operation accepts only the deployment service key and never creates DB-local users or project_members rows.", "x-shennong-service-only": true, "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectShadowUpsert" } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/context-pack": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "getResearchProjectContextPack", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/research-projects/{project_id}/entities": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchEntities", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "upsertResearchEntity", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/activities": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchActivities", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "upsertResearchActivity", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/studies": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchStudies", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "upsertResearchStudy", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/activities/{activity_id}/io": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }, { "$ref": "#/components/parameters/ActivityId" }], "get": { "operationId": "listResearchActivityIo", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "upsertResearchActivityIo", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/activities/{activity_id}/actors": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }, { "$ref": "#/components/parameters/ActivityId" }], "get": { "operationId": "listResearchActivityActors", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "upsertResearchActivityActor", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/associations": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchAssociations", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "proposeResearchAssociation", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/evidence": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchEvidence", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }, "post": { "operationId": "createResearchEvidence", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/associations/{association_id}/evidence": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }, { "$ref": "#/components/parameters/AssociationId" }], "get": { "operationId": "listResearchAssociationEvidence", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/research-projects/{project_id}/associations/{association_id}/evidence/{evidence_id}": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }, { "$ref": "#/components/parameters/AssociationId" }, { "$ref": "#/components/parameters/EvidenceId" }], "put": { "operationId": "linkResearchAssociationEvidence", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/research-projects/{project_id}/resources": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }], "get": { "operationId": "listResearchProjectResources", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/api/v1/research-projects/{project_id}/resources/{resource_id}": { "parameters": [{ "$ref": "#/components/parameters/ProjectId" }, { "$ref": "#/components/parameters/ResourceId" }], "put": { "operationId": "bindResearchProjectResource", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } }, "delete": { "operationId": "unbindResearchProjectResource", "responses": { "204": { "$ref": "#/components/responses/NoContent" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/graph/search": { "post": { "operationId": "searchGraph", "requestBody": { "required": true, "content": { "application/json": { "schema": {} } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "201": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/Invalid" } } } },
    "/api/v1/graph/nodes/{id}": { "parameters": [{ "$ref": "#/components/parameters/Id" }], "get": { "operationId": "getGraphNode", "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/api/v1/graph/subgraph": { "get": { "operationId": "getGraphSubgraph", "parameters": [{ "name": "root", "in": "query", "required": true, "schema": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$" } }, { "name": "depth", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 } }, { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 80 } }, { "name": "project_id", "in": "query", "required": false, "description": "When present, the root and every returned graph row must belong to this project.", "schema": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$" } }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/Invalid" }, "500": { "description": "The graph result failed an internal project-boundary invariant." } } } }
  },
  "components": {
    "securitySchemes": {
