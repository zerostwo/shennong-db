{
  "openapi": "3.1.0",
  "info": { "title": "ShennongDB API", "version": "0.7.0", "description": "WebUI-facing Rust API contract. All product data is owned by the Rust service and persisted in PostgreSQL or object storage." },
  "servers": [{ "url": "/api/v1" }],
  "paths": {
    "/resources": { "get": { "operationId": "listResources", "responses": { "200": { "description": "Visible resources" } } } },
    "/resources/{id}": { "get": { "operationId": "getResource", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Resource" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/resources/{id}/artifacts": { "get": { "operationId": "listArtifacts", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Artifacts" } } } },
    "/resources/{id}/relations": { "get": { "operationId": "listRelations", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Relations" } } } },
    "/resources/{id}/graph-context": { "get": { "operationId": "getResourceGraphContext", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Permission-filtered graph bindings and bounded biological context for a visible Resource" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/projects": {
      "get": { "operationId": "listProjects", "responses": { "200": { "description": "Public projects and private projects visible to the current member" } } },
      "post": { "operationId": "createProject", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "responses": { "200": { "description": "Created private-by-default Project owned by the authenticated user" }, "401": { "$ref": "#/components/responses/Unauthorized" } } }
    },
    "/projects/{id}": { "get": { "operationId": "getProject", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/projects/{id}/context-pack": { "get": { "operationId": "getProjectContextPack", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Compact permission-filtered Agent context; all descriptive metadata is untrusted" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/projects/{id}/entities": {
      "get": { "operationId": "listProjectEntities", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Research entities in a visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "createProjectEntity", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Created or updated entity; Project owner, editor, or administrator only" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/activities": {
      "get": { "operationId": "listProjectActivities", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Research Activities in a visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "createProjectActivity", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Created or updated Activity; Project writer only" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/studies": {
      "get": { "operationId": "listProjectStudies", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Studies in a visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "createProjectStudy", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Created or updated Study with Project path ownership enforced" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/activities/{activity_id}/io": {
      "get": { "operationId": "listProjectActivityIo", "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ActivityId" }], "responses": { "200": { "description": "Activity input/output lineage in a visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "upsertProjectActivityIo", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ActivityId" }], "responses": { "200": { "description": "Upserted IO edge; cross-Project entities are rejected" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/activities/{activity_id}/actors": {
      "get": { "operationId": "listProjectActivityActors", "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ActivityId" }], "responses": { "200": { "description": "Users, Agents, software, instruments, and organizations attributed to an Activity" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "upsertProjectActivityActor", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ActivityId" }], "responses": { "200": { "description": "Upserted Activity actor attribution" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/associations": {
      "get": { "operationId": "listProjectAssociations", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Provenance-bearing Associations in a visible Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "proposeProjectAssociation", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Proposed hypothesis Association; Agent writes cannot self-validate" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/evidence": {
      "get": { "operationId": "listProjectEvidence", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Evidence whose Project and linked local Resources are visible to the caller" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "createProjectEvidence", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Created provenance-bearing Evidence item; Project writer only" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/projects/{id}/associations/{association_id}/evidence": { "get": { "operationId": "listProjectAssociationEvidence", "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/AssociationId" }], "responses": { "200": { "description": "Permission-filtered supporting, contradicting, and neutral Evidence with provenance" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/projects/{id}/associations/{association_id}/evidence/{evidence_id}": {
      "put": { "operationId": "linkProjectAssociationEvidence", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/AssociationId" }, { "$ref": "#/components/parameters/EvidenceId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AssociationEvidenceRequest" } } } }, "responses": { "200": { "description": "Evidence linked after Project and scope validation" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/InvalidRequest" } } }
    },
    "/projects/{id}/resources": { "get": { "operationId": "listProjectResources", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Only bindings to Resources independently visible to the caller" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/projects/{id}/resources/{resource_id}": {
      "put": { "operationId": "bindProjectResource", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ResourceId" }], "responses": { "200": { "description": "Readable Resource bound to Project" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "delete": { "operationId": "unbindProjectResource", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }, { "adminKey": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }, { "$ref": "#/components/parameters/ResourceId" }, { "$ref": "#/components/parameters/BindingRole" }], "responses": { "204": { "description": "Resource binding removed" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/graph/search": { "post": { "operationId": "searchGraph", "responses": { "200": { "description": "Bounded search across graph nodes visible to the caller" }, "422": { "$ref": "#/components/responses/InvalidRequest" } } } },
    "/graph/nodes/{id}": { "get": { "operationId": "getGraphNode", "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Visible graph node" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/graph/subgraph": { "get": { "operationId": "getSubgraph", "parameters": [{ "$ref": "#/components/parameters/Root" }, { "$ref": "#/components/parameters/Depth" }, { "$ref": "#/components/parameters/Limit" }], "responses": { "200": { "description": "Permission-filtered subgraph; depth is 1..3 and limit is at most 200" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/InvalidRequest" } } } },
    "/providers": { "get": { "operationId": "listProviders", "responses": { "200": { "description": "Providers" } } } },
    "/users": { "get": { "operationId": "listUsers", "responses": { "200": { "description": "Users" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/audit-events": { "get": { "operationId": "listAuditEvents", "responses": { "200": { "description": "Audit events" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/auth/register": { "post": { "operationId": "registerUser", "description": "Creates an ordinary user only when instance registration is open, then starts an HttpOnly web session.", "responses": { "200": { "description": "Registered ordinary user session" }, "403": { "description": "Registration is disabled" }, "409": { "description": "Email already exists" } } } },
    "/auth/sign-in": { "post": { "operationId": "signIn", "responses": { "200": { "description": "Session or 2FA challenge" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/auth/verify-2fa": { "post": { "operationId": "verify2fa", "responses": { "200": { "description": "Authenticated session" } } } },
    "/auth/session": { "get": { "operationId": "getSession", "responses": { "200": { "description": "Current HttpOnly web session" } } } },
    "/auth/sign-out": { "post": { "operationId": "signOut", "responses": { "204": { "description": "Signed out" } } } },
    "/auth/tokens": { "get": { "operationId": "listPersonalTokens", "responses": { "200": { "description": "Active personal tokens" } } }, "post": { "operationId": "createPersonalToken", "responses": { "200": { "description": "One-time token secret" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } },
    "/auth/profile": { "get": { "operationId": "getProfile", "responses": { "200": { "description": "Persisted profile" } } }, "put": { "operationId": "updateProfile", "responses": { "200": { "description": "Updated profile" } } } },
    "/auth/sessions": { "get": { "operationId": "listSessions", "responses": { "200": { "description": "Revocable active sessions" } } } },
    "/auth/login-history": { "get": { "operationId": "listLoginHistory", "responses": { "200": { "description": "Persisted login events" } } } },
    "/auth/forgot-password": { "post": { "operationId": "requestPasswordReset", "responses": { "200": { "description": "Reset delivery accepted" }, "503": { "description": "Delivery integration is not configured" } } } },
    "/auth/reset-password": { "post": { "operationId": "resetPassword", "responses": { "204": { "description": "Password reset and existing sessions revoked" } } } },
    "/auth/2fa": { "get": { "operationId": "getTwoFactorStatus", "responses": { "200": { "description": "2FA status" } } }, "delete": { "operationId": "disableTwoFactor", "responses": { "204": { "description": "2FA disabled" } } } },
    "/auth/2fa/enroll": { "post": { "operationId": "enrollTwoFactor", "responses": { "200": { "description": "Pending TOTP enrollment" } } } },
    "/auth/2fa/confirm": { "post": { "operationId": "confirmTwoFactor", "responses": { "200": { "description": "Enabled TOTP and one-time recovery codes" } } } },
    "/ai/providers": {
      "get": { "operationId": "listModelProviders", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "responses": { "200": { "description": "Current user's model connections without credential material" }, "401": { "$ref": "#/components/responses/Unauthorized" } } },
      "post": { "operationId": "createModelProvider", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "responses": { "200": { "description": "Encrypted per-user model connection" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/InvalidRequest" } } }
    },
    "/ai/providers/{id}": {
      "get": { "operationId": "getModelProvider", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Owned model connection without credential material" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "put": { "operationId": "updateModelProvider", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Updated encrypted model connection" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "delete": { "operationId": "deleteModelProvider", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "204": { "description": "Deleted model connection" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/ai/providers/{id}/test": { "post": { "operationId": "testModelProvider", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Connection test result" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/InvalidRequest" } } } },
    "/ai/providers/{id}/models": { "get": { "operationId": "listModelProviderModels", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Models reported by the owned provider" }, "404": { "$ref": "#/components/responses/NotFound" } } } },
    "/chat/threads": {
      "get": { "operationId": "listChatThreads", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "responses": { "200": { "description": "Current user's conversations" } } },
      "post": { "operationId": "createChatThread", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "responses": { "200": { "description": "Created conversation" } } }
    },
    "/chat/threads/{id}": {
      "get": { "operationId": "getChatThread", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Owned conversation" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "put": { "operationId": "updateChatThread", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Updated conversation" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "delete": { "operationId": "deleteChatThread", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "204": { "description": "Deleted conversation" }, "404": { "$ref": "#/components/responses/NotFound" } } }
    },
    "/chat/threads/{id}/messages": {
      "get": { "operationId": "listChatMessages", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Persisted messages, tool events, and citations" }, "404": { "$ref": "#/components/responses/NotFound" } } },
      "post": { "operationId": "runChat", "description": "Runs a bounded Agent turn. Attachments and private Resources require a provider whose data policy explicitly allows private data.", "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Persisted assistant response with tool events and citations" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/InvalidRequest" }, "429": { "description": "Per-user Agent rate or concurrency limit reached" } } }
    },
    "/chat/threads/{id}/run": { "post": { "operationId": "runChatCompatibility", "deprecated": true, "security": [{ "bearerAuth": [] }, { "sessionCookie": [] }], "parameters": [{ "$ref": "#/components/parameters/Id" }], "responses": { "200": { "description": "Persisted assistant response" }, "429": { "description": "Per-user Agent rate or concurrency limit reached" } } } },
    "/search": { "get": { "operationId": "searchWorkspace", "description": "Searches public Resources for guests and the caller's permitted chats, Resources, and Projects when authenticated.", "responses": { "200": { "description": "Permission-filtered workspace search results" } } } },
    "/collections": { "get": { "operationId": "listCollections", "responses": { "200": { "description": "Visible persisted collections" } } }, "post": { "operationId": "createCollection", "responses": { "200": { "description": "Created collection" } } } },
    "/favorites": { "get": { "operationId": "listFavorites", "responses": { "200": { "description": "Current user's favorites" } } } },
    "/uploads": { "get": { "operationId": "listUploads", "responses": { "200": { "description": "Visible upload records" } } }, "post": { "operationId": "uploadFile", "responses": { "200": { "description": "Object stored with verified SHA-256" } } } },
    "/uploads/register": { "post": { "operationId": "registerUploads", "responses": { "200": { "description": "Atomically registered Resource and Artifacts" } } } },
    "/ingestion-jobs": { "get": { "operationId": "listIngestionJobs", "responses": { "200": { "description": "Persisted ingestion jobs" } } } },
    "/grants": { "get": { "operationId": "listGrants", "responses": { "200": { "description": "Persisted grants" } } }, "post": { "operationId": "createGrant", "responses": { "200": { "description": "Persisted grant" } } } },
    "/usage": { "get": { "operationId": "getUsage", "responses": { "200": { "description": "Recorded request, transfer, error, latency, and rate-limit aggregates" } } } },
    "/settings": { "get": { "operationId": "getSettings", "responses": { "200": { "description": "Persisted settings" } } } },
    "/backups": { "get": { "operationId": "listBackups", "responses": { "200": { "description": "Metadata backup history" } } }, "post": { "operationId": "createBackup", "responses": { "200": { "description": "Object-storage metadata snapshot" } } } },
    "/storage": { "get": { "operationId": "getStorageSummary", "responses": { "200": { "description": "Artifact-derived storage metrics" } } } },
    "/admin/overview": { "get": { "operationId": "getAdminOverview", "responses": { "200": { "description": "Catalog, user, upload, and job counts" } } } },
    "/public-config": { "get": { "operationId": "getPublicConfig", "responses": { "200": { "description": "Safe public instance configuration" } } } },
    "/query": { "post": { "operationId": "query", "responses": { "200": { "description": "Query result" }, "401": { "$ref": "#/components/responses/Unauthorized" } } } }
  },
  "components": {
    "parameters": {
      "Id": { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
      "ResourceId": { "name": "resource_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "ActivityId": { "name": "activity_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "AssociationId": { "name": "association_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "EvidenceId": { "name": "evidence_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "BindingRole": { "name": "role", "in": "query", "required": false, "schema": { "type": "string", "default": "data", "maxLength": 128 } },
      "Root": { "name": "root", "in": "query", "required": true, "schema": { "type": "string" } },
      "Depth": { "name": "depth", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 } },
      "Limit": { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 80 } }
    },
    "schemas": {
      "AssociationEvidenceRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stance"],
        "properties": {
          "stance": { "type": "string", "enum": ["supporting", "contradicting", "neutral"] },
          "weight": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "note": { "type": ["string", "null"], "maxLength": 20000 }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" },
      "sessionCookie": { "type": "apiKey", "in": "cookie", "name": "shennong_session" },
      "adminKey": { "type": "apiKey", "in": "header", "name": "x-shennong-admin-key" }
    },
    "responses": {
      "Unauthorized": { "description": "Authentication required" },
      "NotFound": { "description": "Missing or undiscoverable object" },
      "InvalidRequest": { "description": "Invalid identifier, graph bound, or request body" }
    }
  }
}
