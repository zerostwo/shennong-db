# Generate these independently with: openssl rand -hex 32
SHENNONG_ADMIN_API_KEY=replace-with-a-long-random-admin-key
SHENNONG_JWT_SECRET=replace-with-a-different-long-random-jwt-secret
# SHENNONG_JWT_SECRET_PREVIOUS=old-secret-during-key-rotation
SHENNONG_DATA_PATH=./data
SHENNONG_BIND_ADDRESS=127.0.0.1
SHENNONG_PORT=18080
# Pin a semantic-version tag or digest in production.
SHENNONG_IMAGE=zerostwo/shennong-db:0.6.0
# Optional download limits:
# SHENNONG_DOWNLOAD_CONCURRENCY=8
# SHENNONG_DOWNLOAD_TIMEOUT_SECS=300
# SHENNONG_MAX_DOWNLOAD_BYTES=10737418240
# SHENNONG_MAX_UPLOAD_BYTES=53687091200
# Production requires SHA-256 checksums in every Provider file. Set this only
# for an isolated development Provider with explicitly unverified provenance.
# SHENNONG_PROVIDER_ALLOW_UNVERIFIED=0
# Cross-origin requests are disabled unless this comma-separated allowlist is set.
# SHENNONG_CORS_ORIGINS=https://app.example.org
# SHENNONG_MAX_BODY_BYTES=1048576
# SHENNONG_REQUEST_TIMEOUT_SECS=30
# SHENNONG_MAX_CONCURRENCY=64
# SHENNONG_QUERY_MAX_CONCURRENCY=8
# SHENNONG_QUERY_RATE_LIMIT_PER_MINUTE=120
# SHENNONG_DOWNLOAD_RATE_LIMIT_PER_MINUTE=60
# SHENNONG_TRUST_PROXY_HEADERS=0
# SHENNONG_ENABLE_HSTS=0
# SHENNONG_COOKIE_SECURE=0
# SHENNONG_TILEDB_MAX_CONCURRENCY=4
# SHENNONG_TILEDB_TIMEOUT_SECS=30
# SHENNONG_TILEDB_MAX_STDOUT_BYTES=10485760
# SHENNONG_TILEDB_MAX_STDERR_BYTES=65536
# SHENNONG_CLICKHOUSE_CONNECT_TIMEOUT_SECS=3
# SHENNONG_CLICKHOUSE_TIMEOUT_SECS=15
# SHENNONG_CLICKHOUSE_MAX_IDLE_PER_HOST=8
# SHENNONG_CLICKHOUSE_CACHE_TTL_DAYS=30
# SHENNONG_CLICKHOUSE_CACHE_MAX_BYTES=1073741824
# Optional, for restricted or slow outbound networks:
# SHENNONG_DOWNLOAD_PROXY=http://host.docker.internal:7890
