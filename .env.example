SHENNONG_ADMIN_API_KEY=replace-with-a-long-random-admin-key
SHENNONG_JWT_SECRET=replace-with-a-long-random-jwt-secret
SHENNONG_DATA_PATH=./data
SHENNONG_BIND_ADDRESS=127.0.0.1
SHENNONG_PORT=8000
SHENNONG_IMAGE=zerostwo/shennong-db:0.1.0
# Optional, for restricted or slow outbound networks:
# SHENNONG_DOWNLOAD_PROXY=http://host.docker.internal:7890
